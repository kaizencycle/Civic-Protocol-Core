+@router.post("/attest/learning-complete", response_model=LearningCompleteResponse)
+async def attest_learning_complete(req: LearningCompleteRequest):
+    """
+    C-347-D: Issue an Ed25519-signed OAA tutor session completion proof.
+    Anchors to the civic ledger when keys and LEDGER_URL are configured.
+    """
+    content = {
+        "type": req.type,
+        "session_id": req.session_id,
+        "module_id": req.module_id,
+        "subject_id": req.subject_id,
+        "mic_earned": req.mic_earned,
+        "accuracy": req.accuracy,
+        "oaa_policy_version": "default_policy.yaml",
+        "oaa_version": "lab7-v1",
+        "ts": req.ts,
+        "nonce": req.nonce,
+    }
+
+    attestation = None
+    attestation_id = None
+    content_hash = None
+    priv_b64 = os.getenv("OAA_ED25519_PRIVATE_B64", "")
+    pub_b64 = os.getenv("OAA_ED25519_PUBLIC_B64", "")
+    ledger_url = os.getenv("LEDGER_URL", "").rstrip("/")
+
+    try:
+        if priv_b64 and pub_b64:
+            content_hash, sig_b64 = ed25519_sign(priv_b64, content)
+            attestation_id = f"attest-{content_hash[:16]}"
+            attestation = {
+                "content": content,
+                "content_hash": f"sha256:{content_hash}",
+                "signature": f"ed25519:{sig_b64}",
+                "public_key_b64": pub_b64,
+                "signing_key": "oaa:ed25519:v1",
+            }
+            if ledger_url:
+                async with httpx.AsyncClient(timeout=15) as client:
+                    r = await client.post(f"{ledger_url}/attest", json=attestation)
+                    r.raise_for_status()
+                    attestation["ledger_receipt"] = r.json()
+        else:
+            content_hash = sha256_hex(content)
+            attestation_id = f"attest-{content_hash[:16]}"
+            attestation = {"content": content, "content_hash": f"sha256:{content_hash}"}
+    except Exception as e:
+        content_hash = content_hash or sha256_hex(content)
+        attestation_id = attestation_id or f"attest-{content_hash[:16]}"
+        attestation = attestation or {"content": content, "error": str(e)}
+
+    verify_base = os.getenv("LAB7_PUBLIC_BASE", "").rstrip("/")
+    verification_url = (
+        f"{verify_base}/oaa/verify" if verify_base else "/oaa/verify"
+    )
+
+    return LearningCompleteResponse(
+        ok=True,
+        attestation_id=attestation_id,
+        credential_id=attestation_id,
+        content_hash=f"sha256:{content_hash}" if content_hash else None,
+        attestation=attestation,
+        verification_url=verification_url,
+    )
+
+
 @router.post("/verify", response_model=VerifyResponse)
