+"""C-347-D: learning completion attestation endpoint."""
+
+from fastapi.testclient import TestClient
+
+from src.app.main import app
+
+client = TestClient(app)
+
+
+def test_learning_complete_attestation_returns_credential():
+    resp = client.post(
+        "/oaa/attest/learning-complete",
+        json={
+            "type": "oaa.tutor.session_complete",
+            "session_id": "sess-test-1",
+            "module_id": "mod-intro",
+            "subject_id": "user-abc",
+            "mic_earned": 5.0,
+            "accuracy": 0.92,
+            "ts": "2026-06-19T12:00:00Z",
+            "nonce": "nonce-123",
+        },
+    )
+    assert resp.status_code == 200, resp.text
+    data = resp.json()
+    assert data["ok"] is True
+    assert data["attestation_id"]
+    assert data["credential_id"] == data["attestation_id"]
+    assert data["content_hash"]
