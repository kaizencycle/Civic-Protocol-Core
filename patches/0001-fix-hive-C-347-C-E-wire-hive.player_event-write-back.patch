@@ -0,0 +1,63 @@
+import { env } from '../../config/env';
+
+export interface RedeemRequest {
+  item_id: string;
+  idempotency_key?: string;
+}
+
+export interface RedeemResponse {
+  ok: boolean;
+  item_id: string;
+  unlock_token: string;
+  new_balance: number;
+  already_redeemed?: boolean;
+}
+
+export interface UnlockStatus {
+  unlocks: string[];
+}
+
+function authHeaders(token: string): HeadersInit {
+  return {
+    'Content-Type': 'application/json',
+    Authorization: `Bearer ${token}`,
+  };
+}
+
+export async function redeemMicItem(
+  token: string,
+  itemId: string,
+  idempotencyKey?: string,
+): Promise<RedeemResponse> {
+  const base = env.api.micWallet.replace(/\/$/, '');
+  const res = await fetch(`${base}/mic/redeem`, {
+    method: 'POST',
+    headers: authHeaders(token),
+    body: JSON.stringify({ item_id: itemId, idempotency_key: idempotencyKey }),
+    signal: AbortSignal.timeout(10000),
+  });
+
+  if (!res.ok) {
+    const detail = await res.text().catch(() => '');
+    throw new Error(detail || `redeem_${res.status}`);
+  }
+
+  return res.json() as Promise<RedeemResponse>;
+}
+
+export async function fetchMicUnlocks(token: string): Promise<UnlockStatus> {
+  const base = env.api.micWallet.replace(/\/$/, '');
+  const res = await fetch(`${base}/mic/unlocks`, {
+    headers: authHeaders(token),
+    signal: AbortSignal.timeout(8000),
+  });
+
+  if (!res.ok) {
+    throw new Error(`unlocks_${res.status}`);
+  }
+
+  return res.json() as Promise<UnlockStatus>;
+}
+
+/** First gated realm in the C-342 ten-realm map — unlock costs 10 MIC. */
+export const REALM_OF_SELF_UNLOCK = 'realm-of-self';
