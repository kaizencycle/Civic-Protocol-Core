+/**
+ * HiveRealmUnlock — minimal C-347-E redemption stub.
+ * Spend MIC to unlock the Realm of Self chamber (first gated realm in C-342 map).
+ */
+import React, { useCallback, useEffect, useState } from 'react';
+import { Lock, Unlock } from 'lucide-react';
+import { useAuth } from '../../../contexts/AuthContext';
+import { useWallet } from '../../../contexts/WalletContext';
+import {
+  fetchMicUnlocks,
+  redeemMicItem,
+  REALM_OF_SELF_UNLOCK,
+} from '../../../src/lib/hive-redeem';
+
+const REALM_COST_MIC = 10;
+
+export const HiveRealmUnlock: React.FC = () => {
+  const { token, status } = useAuth();
+  const { wallet, refreshWallet } = useWallet();
+  const [unlocked, setUnlocked] = useState(false);
+  const [loading, setLoading] = useState(false);
+  const [error, setError] = useState<string | null>(null);
+  const [open, setOpen] = useState(false);
+
+  useEffect(() => {
+    if (!token) return;
+    let cancelled = false;
+    fetchMicUnlocks(token)
+      .then((res) => {
+        if (!cancelled) {
+          setUnlocked(res.unlocks.includes(REALM_OF_SELF_UNLOCK));
+        }
+      })
+      .catch(() => {
+        /* unlock list unavailable — stay locked */
+      });
+    return () => {
+      cancelled = true;
+    };
+  }, [token]);
+
+  const onRedeem = useCallback(async () => {
+    if (!token) return;
+    setLoading(true);
+    setError(null);
+    try {
+      const result = await redeemMicItem(token, REALM_OF_SELF_UNLOCK);
+      setUnlocked(true);
+      await refreshWallet();
+      if (result.already_redeemed) {
+        setError(null);
+      }
+    } catch (e) {
+      setError(e instanceof Error ? e.message : 'Redemption unavailable');
+    } finally {
+      setLoading(false);
+    }
+  }, [token, refreshWallet]);
+
+  const balance = wallet?.balance ?? 0;
+  const canAfford = balance >= REALM_COST_MIC;
+  const needsAuth = status !== 'authenticated' || !token;
+
+  return (
+    <div className="border-t border-gray-800/60 px-3 py-1.5 font-mono text-[10px]">
+      <button
+        type="button"
+        onClick={() => setOpen((o) => !o)}
+        className="flex items-center gap-1.5 text-stone-400 hover:text-amber-300 transition-colors"
+      >
+        {unlocked ? <Unlock className="w-3 h-3 text-teal-400" /> : <Lock className="w-3 h-3" />}
+        <span className="uppercase tracking-wider">Realm unlock</span>
+        <span className="text-stone-600">{open ? '▾' : '▸'}</span>
+      </button>
+
+      {open && (
+        <div className="mt-1.5 pl-4 text-stone-400 space-y-1">
+          <p>
+            <span className="text-amber-300">Realm of Self</span>
+            {' — '}
+            {unlocked ? (
+              <span className="text-teal-400">unlocked</span>
+            ) : (
+              <span>{REALM_COST_MIC} MIC</span>
+            )}
+          </p>
+
+          {needsAuth ? (
+            <p className="text-stone-500 italic">Sign in to redeem chamber access</p>
+          ) : unlocked ? (
+            <p className="text-teal-400/80">Chamber available in the HIVE map</p>
+          ) : (
+            <>
+              <p className="text-stone-500">Balance: {balance.toFixed(1)} MIC</p>
+              {!canAfford && (
+                <p className="text-amber-400/90">Insufficient balance — earn more MIC first</p>
+              )}
+              {error && <p className="text-rose-400">{error}</p>}
+              <button
+                type="button"
+                disabled={loading || !canAfford}
+                onClick={() => void onRedeem()}
+                className="mt-1 px-2 py-0.5 rounded border border-amber-500/40 text-amber-300 disabled:opacity-40 disabled:cursor-not-allowed hover:bg-amber-500/10"
+              >
+                {loading ? 'Redeeming…' : 'Unlock realm'}
+              </button>
+            </>
+          )}
+        </div>
+      )}
+    </div>
+  );
+};
