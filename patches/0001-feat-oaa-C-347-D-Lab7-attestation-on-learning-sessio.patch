+"""C-347-D: Non-blocking Lab7 completion attestation for OAA learning sessions."""
+
+from __future__ import annotations
+
+import logging
+import os
+import uuid
+from datetime import datetime, timezone
+from typing import Any
+
+import httpx
+
+logger = logging.getLogger("oaa.lab7_attestation")
+
+LAB7_API_BASE = os.getenv("LAB7_API_BASE", "https://lab7-proof.onrender.com").rstrip("/")
+LAB7_ATTEST_TIMEOUT = float(os.getenv("LAB7_ATTEST_TIMEOUT_SECONDS", "5"))
+
+
+async def request_learning_completion_attestation(
+    *,
+    session_id: str,
+    module_id: str,
+    subject_id: str,
+    mic_earned: float,
+    accuracy: float,
+) -> dict[str, Any]:
+    """
+    Request an Ed25519-signed completion proof from Lab7.
+    Returns {status, attestation_id?, credential_id?, error?}.
+  Never raises — callers treat failures as pending attestation.
+    """
+    payload = {
+        "type": "oaa.tutor.session_complete",
+        "session_id": session_id,
+        "module_id": module_id,
+        "subject_id": subject_id,
+        "mic_earned": mic_earned,
+        "accuracy": accuracy,
+        "ts": datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
+        "nonce": str(uuid.uuid4()),
+    }
+
+    try:
+        async with httpx.AsyncClient(timeout=LAB7_ATTEST_TIMEOUT) as client:
+            resp = await client.post(
+                f"{LAB7_API_BASE}/oaa/attest/learning-complete",
+                json=payload,
+            )
+            if resp.status_code >= 400:
+                logger.warning(
+                    "Lab7 attestation failed: %s %s",
+                    resp.status_code,
+                    resp.text[:200],
+                )
+                return {
+                    "status": "pending_attestation",
+                    "error": f"lab7_{resp.status_code}",
+                }
+
+            data = resp.json()
+            attestation_id = data.get("attestation_id") or data.get("content_hash")
+            credential_id = data.get("credential_id") or attestation_id
+            return {
+                "status": "attested",
+                "attestation_id": attestation_id,
+                "credential_id": credential_id,
+                "verification_url": data.get("verification_url"),
+            }
+    except Exception as exc:
+        logger.warning("Lab7 attestation unreachable: %s", exc)
+        return {"status": "pending_attestation", "error": str(exc)}
